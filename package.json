{
  "name": "reversal-api",
  "version": "1.0.0",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "server:smoke": "node scripts/server-smoke.cjs",
    "smoke:full": "node scripts/full-platform-smoke.js",
    "test:ml": "node scripts/test-ml-inference.cjs",
    "check:server": "node --check server/index.cjs",
    "test": "node --test --test-concurrency=1 server/tests/*.test.js",
    "build": "node --check server/index.cjs && node --check server.js"
  },
  "engines": {
    "node": "20.x"
  },
  "dependencies": {
    "express": "^4.19.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "jsonwebtoken": "^9.0.2",
    "bcrypt": "^5.1.1",
    "better-sqlite3": "^11.9.1",
    "socket.io": "^4.8.1",
    "mongoose": "^8.15.1"
  }
}
